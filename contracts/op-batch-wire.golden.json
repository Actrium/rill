        "version": 1,
        "batchId": 1,
        "operations": [{ "op": "CREATE", "id": 1, "type": "View", "props": {} }]
      },
      "hex": "52494c4c0100010000000100000000000100040056696577010100000000000000",
      "byteLength": 33,
      "breakdown": [
        { "bytes": "52494c4c", "field": "magic" },
        { "bytes": "0100", "field": "version = 1" },
